# Copy to .env and fill in, or: export ODDS_API_KEY=...
# Get a key at https://the-odds-api.com/
ODDS_API_KEY=

# Optional: allow new sign-ups in the app (default off)
# MLB_ALLOW_REGISTRATION=1

# Optional: auto-create first user when DB is empty (Streamlit Cloud: use Secrets instead)
# MLB_BOOTSTRAP_EMAIL=you@example.com
# MLB_BOOTSTRAP_PASSWORD=your-secure-password
